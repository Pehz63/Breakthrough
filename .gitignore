# Build directories
build/
Build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# Temporary files
*.tmp
*.log
*.bak
*.swp

# vcpkg
vcpkg_installed/

# Downloaded dependencies (raylib native + web builds). Fetch per INSTALL.md.
third_party/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/

# ML generated artifacts (regenerated by train.exe). Keep .gitkeep + manifests,
# ignore the bulky append-only streams, per-epoch checkpoints, and demo exports.
data/*.jsonl
models/*_ckpt*.txt
models/py_linear.txt
agents/library.txt

# Run archive: keep the curated, human-readable history (config.json, elo.tsv,
# notes.md, runs/index.jsonl, agents/registry.*), but ignore each run's bulky
# results.jsonl copy (it mirrors the already-ignored data/tourney.jsonl).
runs/**/results.jsonl

# Agent Elo ranking (rank.exe). Unlike data/*.jsonl, ranking/matches.jsonl is
# deliberately KEPT: it is the never-recomputed match history the ratings are
# built from. Only per-shard temp files and the gauntlet scratch are ignored.
ranking/matches.jsonl.*
ranking/gauntlet.jsonl
