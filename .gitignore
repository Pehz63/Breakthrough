vcpkg_installed/

# Downloaded dependencies (raylib native + web builds). Fetch per INSTALL.md.
third_party/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/

# ML generated artifacts (regenerated by train.exe). Keep .gitkeep + manifests,
# ignore the bulky append-only streams, per-epoch checkpoints, and demo exports.
# data/*.meta.json covers pairgen recipe sidecars and shard logs live with them.
data/*.jsonl
data/*.jsonl.*
data/*.meta.json
models/*_ckpt*.txt
models/py_linear.txt
agents/library.txt

# Run archive: keep the curated, human-readable history (config.json, elo.tsv,
# notes.md, runs/index.jsonl, agents/registry.*), but ignore each run's bulky
# results.jsonl copy (it mirrors the already-ignored data/tourney.jsonl).
runs/**/results.jsonl

# Agent Elo ranking (rank.exe). Unlike data/*.jsonl, ranking/matches.jsonl is
# deliberately KEPT: it is the never-recomputed match history the ratings are
# built from. Only per-shard temp files and the gauntlet scratch are ignored.
ranking/matches.jsonl.*
ranking/gauntlet.jsonl
ranking/climb_*.tsv

# Training hyperparameter sweeps (tools/sweep_pst.ps1): throwaway model
# checkpoints + generated report, regenerable by re-running the sweep.
# Exceptions: the vs-champion study's promoted family models (slots 94..99)
# are referenced by hash from the committed ranking/roster.txt, so they must
# travel with the repo, and vs_champ.csv is that study's durable record.
models/sweep/*
!models/sweep/vs_champ.csv
!models/sweep/slot94.txt
!models/sweep/slot95.txt
!models/sweep/slot96.txt
!models/sweep/slot97.txt
!models/sweep/slot98.txt
!models/sweep/slot99.txt
